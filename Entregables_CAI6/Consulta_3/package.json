{
  "name": "health-procurement-auction",
  "version": "1.0.0",
  "description": "Vickrey reverse auction smart contract for Servicio de Salud Publico (CAI 6.3)",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "verify:sepolia": "hardhat verify --network sepolia",
    "static:slither": "slither HealthProcurementAuction.sol --solc-remaps '@openzeppelin/=node_modules/@openzeppelin/' --json reports/slither.json || true",
    "static:mythril": "myth analyze HealthProcurementAuction.sol --solv 0.8.24 -o markdown > reports/mythril.md || true"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0"
  }
}
